<wpfLikeAvaloniaNavigation:Page xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:wpfLikeAvaloniaNavigation="clr-namespace:WpfLikeAvaloniaNavigation;assembly=WpfLikeAvaloniaNavigation"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="CosmeticMess.Views.Desktop.AccountDesktop" Background="#f6f6f6" Foreground="#8785a2" FontFamily="Georgia">
    <Grid RowDefinitions="Auto, *" ColumnDefinitions="*, *">
        <Border Grid.Row="0" Grid.ColumnSpan="2" BorderBrush="#ffc7c7" BorderThickness="3" CornerRadius="6" Margin="10,10,10,10">
            <StackPanel Orientation="Horizontal" Margin="10,10,10,10" Spacing="5">
                <TextBlock Text="Здравствуйте" FontSize="20" Margin="5" FontWeight="SemiBold"/>
                <TextBlock Text="{Binding User.Name}" FontSize="20" Margin="5" FontWeight="SemiBold"/>
                <TextBlock Text="{Binding User.LastName}" FontSize="20" Margin="5" FontWeight="SemiBold"/>
                <Button Content="На главную" x:Name="ToMain" Click="ToMain_OnClick" Background="#ffe2e2" Foreground="#8785a2" FontFamily="Georgia" FontSize="20"/>
            </StackPanel>
        </Border>
        
        <Expander Grid.Row="1" Grid.Column="0" HorizontalAlignment="Stretch" VerticalAlignment="Top" Margin="10,10,10,10" IsExpanded="True">
            <Expander.Header>
                <StackPanel Orientation="Horizontal" Spacing="5">
                    <TextBlock Text="История заказов" FontSize="20" FontFamily="Georgia" Margin="5" FontWeight="SemiBold" Foreground="#8785a2"/>
                </StackPanel>
            </Expander.Header>
            <Grid HorizontalAlignment="Stretch">
                <ListBox ItemsSource="{Binding Orders}">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border BorderBrush="#ffc7c7" BorderThickness="5" CornerRadius="6">
                                <StackPanel Orientation="Vertical" Spacing="10" Margin="10,10,10,10">
                                    <StackPanel Orientation="Horizontal" Spacing="5">
                                        <TextBlock Text="Дата оформления заказа:"/>
                                        <TextBlock Text="{Binding Date}"/>    
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Spacing="5">
                                        <TextBlock Text="Дата доставки:"/>
                                        <TextBlock Text="{Binding DeliveryDate}" />    
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Spacing="5">
                                        <TextBlock Text="Статус заказа:"/>
                                        <TextBlock Text="{Binding Status.Name}"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox> 
            </Grid>
        </Expander>
        
        <Expander Grid.Row="1" Grid.Column="1" VerticalAlignment="Top" Margin="10,10,10,10" HorizontalAlignment="Stretch" IsExpanded="True">
            <Expander.Header>
                <StackPanel Orientation="Horizontal" Spacing="5">
                    <TextBlock Text="История записей" FontSize="20" FontFamily="Georgia" Margin="5" FontWeight="SemiBold" Foreground="#8785a2"/>
                </StackPanel>
            </Expander.Header>
            <Grid HorizontalAlignment="Stretch">
                <ListBox ItemsSource="{Binding Records}">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border BorderBrush="#ffc7c7" BorderThickness="5" CornerRadius="6" >
                                <StackPanel Orientation="Vertical" Spacing="5" Margin="10,10,10,10">
                                    <StackPanel Orientation="Horizontal" Spacing="5">
                                        <TextBlock Text="Дата записи:"/>
                                        <TextBlock Text="{Binding Date}"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Spacing="5">
                                        <TextBlock Text="Тип записи:"/>
                                        <TextBlock Text="{Binding ServiceType.Name}"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Spacing="5">
                                        <TextBlock Text="Цена:"/>
                                        <TextBlock Text="{Binding ServiceType.Price}"/>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Spacing="5">
                                        <TextBlock Text="Статус:"/>
                                        <TextBlock Text="{Binding Status.Name}"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox> 
            </Grid>
        </Expander>
    </Grid>
</wpfLikeAvaloniaNavigation:Page>
