<wpfLikeAvaloniaNavigation:Page xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:wpfLikeAvaloniaNavigation="clr-namespace:WpfLikeAvaloniaNavigation;assembly=WpfLikeAvaloniaNavigation"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="CosmeticMess.Views.Desktop.AccountDesktop" Background="#f6f6f6" Foreground="#8785a2" FontFamily="Georgia">
    <Grid RowDefinitions="Auto, *" ColumnDefinitions="Auto, *">
        <Border Grid.Row="0" Grid.ColumnSpan="2" BorderBrush="#ffc7c7" BorderThickness="3" CornerRadius="6" Margin="10,10,10,10">
            <StackPanel Orientation="Horizontal" Margin="10,10,10,10" Spacing="10">
                <TextBlock Text="Здравствуйте" FontSize="20" Margin="5" FontWeight="SemiBold"/>
                <TextBlock Text="{Binding Name}" FontSize="20" Margin="5" FontWeight="SemiBold"/>
                <TextBlock Text="{Binding LastName}" FontSize="20" Margin="5" FontWeight="SemiBold"/>
                <Button Content="На главную" x:Name="ToMain" Click="ToMain_OnClick" Background="#ffe2e2" Foreground="#8785a2" FontFamily="Georgia" FontSize="20"/>
            </StackPanel>
        </Border>
    </Grid>
</wpfLikeAvaloniaNavigation:Page>
