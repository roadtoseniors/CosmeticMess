<wpfLikeAvaloniaNavigation:Page xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:wpfLikeAvaloniaNavigation="clr-namespace:WpfLikeAvaloniaNavigation;assembly=WpfLikeAvaloniaNavigation"
             mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="600"
             x:Class="CosmeticMess.Views.Desktop.AdminDesktop"
             Background="#f6f6f6" Foreground="#8785a2" FontFamily="Georgia">

    <Grid RowDefinitions="Auto, *">
        <Border Grid.Row="0" Background="#fff0f0" BorderBrush="#ffc7c7" BorderThickness="0,0,0,2" Margin="10,10,10,10" CornerRadius="6">
            <Grid ColumnDefinitions="*, Auto">
                <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center" Margin="10,10,10,10">
                    <TextBlock Text="Панель администратора" FontSize="20" FontWeight="SemiBold" VerticalAlignment="Center" Foreground="#6b6882"/>
                    <TextBlock x:Name="CountText" FontSize="13" Foreground="#8785a2" Margin="10,10,10,10"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                    <Button Content="Добавить" Background="#ffc7c7" Foreground="#6b6882" FontFamily="Georgia" FontSize="15" FontWeight="SemiBold" CornerRadius="20" Padding="16,6" Click="Add_OnClick" BorderThickness="0"/>
                    <Button Content="Назад" Background="Transparent" Foreground="#b0aec0" FontFamily="Georgia" FontSize="15" CornerRadius="20" Padding="12,6" Click="Back_OnClick" BorderThickness="0"/>
                </StackPanel>
            </Grid>
        </Border>

        <ScrollViewer Grid.Row="1" Margin="10,10,10,10">
            <ItemsControl x:Name="UsersList">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="White" BorderBrush="#ffdede" BorderThickness="1.5" CornerRadius="12" Margin="0,0,0,10" Padding="16,12">
                            <Grid ColumnDefinitions="Auto, *, Auto, Auto">
                                <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <TextBlock FontSize="16" FontWeight="SemiBold" Foreground="#5c5a72">
                                            <TextBlock.Text>
                                                <MultiBinding StringFormat="{}{0} {1}">
                                                    <Binding Path="Name"/>
                                                    <Binding Path="LastName"/>
                                                </MultiBinding>
                                            </TextBlock.Text>
                                        </TextBlock>
                                        <TextBlock Text="{Binding Role.Name}" FontSize="11" Foreground="#7a7a9a" Margin="5"/>
                                        <Border Background="{Binding FrozenBadgeColor}" CornerRadius="8" Padding="8,2" IsVisible="{Binding IsFrozen}">
                                            <TextBlock Text="заморожен" FontSize="11" Foreground="#7a9ab5"/>
                                        </Border>
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" Spacing="16">
                                        <TextBlock FontSize="13" Opacity="0.6">
                                            <TextBlock.Text>
                                                <MultiBinding StringFormat="{}{0}">
                                                    <Binding Path="Login"/>
                                                </MultiBinding>
                                            </TextBlock.Text>
                                        </TextBlock>
                                        <TextBlock Text="{Binding Phone}" FontSize="13" Opacity="0.6"/>
                                        <TextBlock FontSize="13" Opacity="0.5">
                                            <TextBlock.Text>
                                                <MultiBinding StringFormat="{}{0} лет">
                                                    <Binding Path="Age"/>
                                                </MultiBinding>
                                            </TextBlock.Text>
                                        </TextBlock>
                                    </StackPanel>
                                </StackPanel>

                                <Button Grid.Column="2" Content="{Binding FrozenLabel}" Background="{Binding FrozenColor}" Foreground="#8785a2" FontFamily="Georgia" FontSize="13" CornerRadius="16" Padding="12,5" Margin="8,0" BorderThickness="0" Click="Frozen_OnClick" VerticalAlignment="Center"/>
                                <Button Grid.Column="3" Content="Изменить" Background="#ffe2e2" Foreground="#8785a2" FontFamily="Georgia" FontSize="13" CornerRadius="16" Padding="12,5" BorderThickness="0" Click="Edit_OnClick" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

    </Grid>
</wpfLikeAvaloniaNavigation:Page>