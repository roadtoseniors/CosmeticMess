<wpfLikeAvaloniaNavigation:Page xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:wpfLikeAvaloniaNavigation="clr-namespace:WpfLikeAvaloniaNavigation;assembly=WpfLikeAvaloniaNavigation"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="CosmeticMess.Views.Desktop.AdminDesktop"
             Background="#f6f6f6" Foreground="#8785a2" FontFamily="Georgia">
    <Grid RowDefinitions="Auto, *">
        <Border Grid.Row="0" BorderBrush="#ffc7c7" BorderThickness="3" CornerRadius="6" Margin="10,10,10,5">
            <StackPanel Orientation="Horizontal" Margin="10" Spacing="10">
                <TextBlock Text="Панель администратора" FontSize="20" FontWeight="SemiBold" VerticalAlignment="Center"/>
                <Button Content="Добавить" Background="#ffe2e2" Foreground="#8785a2" FontFamily="Georgia" FontSize="18" Click="Add_OnClick"/>
                <Button Content="Назад" Background="#ffe2e2" Foreground="#8785a2" FontFamily="Georgia" FontSize="18" Click="Back_OnClick"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="1" BorderBrush="#ffc7c7" BorderThickness="3" CornerRadius="6" Margin="10,5,10,10">
            <ScrollViewer HorizontalScrollBarVisibility="Auto">
                <DataGrid x:Name="UsersGrid" ItemsSource="{Binding Users}" IsReadOnly="True" CanUserReorderColumns="False">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="Auto"/>
                        <DataGridTextColumn Header="Имя" Binding="{Binding Name}" Width="Auto"/>
                        <DataGridTextColumn Header="Фамилия" Binding="{Binding LastName}" Width="Auto"/>
                        <DataGridTextColumn Header="Телефон" Binding="{Binding Phone}" Width="Auto"/>
                        <DataGridTextColumn Header="Возраст" Binding="{Binding Age}" Width="Auto"/>
                        <DataGridTextColumn Header="Роль" Binding="{Binding Role.Name}" Width="Auto"/>
                        <DataGridTextColumn Header="Логин" Binding="{Binding Login}" Width="Auto"/>
                        <DataGridTemplateColumn Header="Заморожен" Width="Auto">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Content="{Binding FrozenLabel}" Background="{Binding FrozenColor}" Foreground="#8785a2" FontFamily="Georgia" Click="Frozen_OnClick"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Header="Действие" Width="Auto">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Content="Изменить" Background="#ffe2e2" Foreground="#8785a2" FontFamily="Georgia" Click="Edit_OnClick"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </ScrollViewer>
        </Border>
    </Grid>
</wpfLikeAvaloniaNavigation:Page>