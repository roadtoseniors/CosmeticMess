<wpfLikeAvaloniaNavigation:Page xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:wpfLikeAvaloniaNavigation="clr-namespace:WpfLikeAvaloniaNavigation;assembly=WpfLikeAvaloniaNavigation"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="CosmeticMess.Views.Desktop.RecordDesktop" Background="#f6f6f6" Foreground="#8785a2" FontFamily="Georgia">
    <Grid RowDefinitions="Auto, *" ColumnDefinitions="*">
        <Border Grid.Row="0" Grid.Column="0" BorderBrush="#ffc7c7" BorderThickness="3" CornerRadius="6" Margin="10,10,10,10">
            <StackPanel Orientation="Horizontal" Spacing="5" Margin="10,10,10,10">
                <TextBlock Text="Страница записей" FontSize="20" FontFamily="Georgia" Margin="5" FontWeight="SemiBold"/>
                <Button Content="Фильтровать по дате" Background="#ffe2e2" Foreground="#8785a2" FontFamily="Georgia" FontSize="20" x:Name="Filtre" Click="Filtre_OnClick"/>
                <Button Content="На главную" Background="#ffe2e2" Foreground="#8785a2" FontFamily="Georgia" FontSize="20" x:Name="Back" Click="Back_OnClick"/>
            </StackPanel>
        </Border>
        
        <Border Grid.Row="1" Grid.Column="0" BorderBrush="#ffc7c7" BorderThickness="3" CornerRadius="6" Margin="10,10,10,10">
            <ScrollViewer HorizontalScrollBarVisibility="Auto">
                <DataGrid ItemsSource="{Binding Records}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Имя мастера" Binding="{Binding Master.Name}" Width="Auto"/>
                        <DataGridTextColumn Header="Фамилия мастера" Binding="{Binding Master.LastName}" Width="Auto"/>
                        <DataGridTextColumn Header="Услуга" Binding="{Binding ServiceTypes.Name}" Width="Auto"/>
                        <DataGridTextColumn Header="Дата" Binding="{Binding Date}" Width="Auto"/>
                        <DataGridTextColumn Header="Тип оплаты" Binding="{Binding Payment.Name}" Width="Auto"/>
                        <DataGridTextColumn Header="Статус" Binding="{Binding Status.Name}" Width="Auto"/>
                        <DataGridTemplateColumn Header="Действие" Width="Auto">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Content="Записаться" x:Name="SelectedRecord" Click="SelectedRecord_OnClick" Width="70"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </ScrollViewer>
        </Border>
    </Grid>
</wpfLikeAvaloniaNavigation:Page>
