<wpfLikeAvaloniaNavigation:Page xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:wpfLikeAvaloniaNavigation="clr-namespace:WpfLikeAvaloniaNavigation;assembly=WpfLikeAvaloniaNavigation"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             x:Class="CosmeticMess.Views.Desktop.MasterDesktop" Background="#f6f6f6" Foreground="#8785a2" FontFamily="Georgia">
    <Grid RowDefinitions="Auto, Auto, Auto, *">
        <Border Grid.Row="0" BorderBrush="#ffc7c7" BorderThickness="3" CornerRadius="6" Margin="10,10,10,10">
            <StackPanel Orientation="Horizontal" Spacing="10" Margin="10,10,10,10">
                <TextBlock Text="Страница мастера" FontSize="20" FontFamily="Georgia" Margin="5" FontWeight="SemiBold"/>
                <Button Content="На главную" Background="#ffe2e2" Foreground="#8785a2" FontFamily="Georgia" FontSize="20" Click="Back_OnClick"/>
            </StackPanel>
        </Border>
        
        <Border Grid.Row="1" BorderBrush="#ffc7c7" BorderThickness="3" CornerRadius="6" Margin="10,5,10,5">
            <StackPanel Margin="10" Spacing="6">
                <TextBlock Text="Мои услуги" FontSize="15" FontWeight="SemiBold"/>
                <ItemsControl ItemsSource="{Binding MyServices}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal" ItemSpacing="5"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" Spacing="2" Margin="0,2">
                                <Button Background="#ffe2e2" Foreground="#8785a2" Content="{Binding ServiceType.Name}" FontSize="15"/>
                                <Button Content="Удалить" Background="#ffc7c7" Foreground="#8785a2" Click="RemoveService_OnClick"/>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </Border>
        
        <Border Grid.Row="2" BorderBrush="#ffc7c7" BorderThickness="3" CornerRadius="6" Margin="10,5,10,5">
            <StackPanel Orientation="Horizontal" Spacing="10" Margin="10">
                <TextBlock Text="Добавить услугу:" FontSize="15" VerticalAlignment="Center"/>
                <ComboBox x:Name="ServiceComboBox" ItemsSource="{Binding AvailableServices}" PlaceholderText="Выберите услугу" Width="200" FontSize="15">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Name}"/>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
                <Button Content="Добавить" Background="#ffe2e2" Foreground="#8785a2" FontFamily="Georgia" FontSize="15" Click="AddService_OnClick"/>
            </StackPanel>
        </Border>
        
        <Border Grid.Row="3" BorderBrush="#ffc7c7" BorderThickness="3" CornerRadius="6" Margin="10,5,10,10">
            <Grid RowDefinitions="Auto, *">
                <TextBlock Grid.Row="0" Text="Мои записи" FontSize="15" FontWeight="SemiBold" Margin="14,8,0,4"/>
                <ScrollViewer Grid.Row="1">
                    <ItemsControl ItemsSource="{Binding Records}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="#ffc7c7" BorderThickness="2" CornerRadius="6" Margin="8,4" Padding="12" Background="White" PointerPressed="Record_OnClick">
                                    <StackPanel Orientation="Horizontal" Spacing="20">
                                        <TextBlock Text="{Binding Date, StringFormat={}{0:dd.MM.yyyy HH:mm}}" FontSize="15" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                        <TextBlock Text="{Binding ServiceType.Name}" FontSize="14" VerticalAlignment="Center" Opacity="0.8"/>
                                        <TextBlock Text="{Binding Status.Name}" FontSize="13" VerticalAlignment="Center" Foreground="#c0392b"/>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</wpfLikeAvaloniaNavigation:Page>
