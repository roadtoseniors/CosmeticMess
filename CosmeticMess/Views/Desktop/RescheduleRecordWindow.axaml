<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="CosmeticMess.Views.Desktop.RescheduleRecordWindow"
        Title="RescheduleRecordWindow">
    <StackPanel Spacing="10" Margin="20">
        <TextBlock Text="Перенос записи" FontSize="20" FontWeight="SemiBold"/>

        <TextBlock Text="Новая дата" FontSize="13" Opacity="0.7"/>
        <CalendarDatePicker x:Name="DatePicker" HorizontalAlignment="Stretch" FontSize="15"/>

        <TextBlock Text="Новое время" FontSize="13" Opacity="0.7"/>
        <TimePicker x:Name="TimePicker" HorizontalAlignment="Stretch" FontSize="15"/>

        <TextBlock x:Name="ErrorText" Foreground="Red" FontSize="13" IsVisible="False"/>
        <Button Content="Перенести" Background="#ffc7c7" Foreground="#8785a2"
                FontFamily="Georgia" FontSize="18" HorizontalAlignment="Stretch"
                Height="44" Click="Save_OnClick"/>
    </StackPanel>
</Window>
